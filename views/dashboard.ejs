<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UbeurIT</title>

<style>
:root {
  --primary: #5865F2;
  --primary-light: #EEF0FF;
  --background: #f5f7fb;
  --card: #ffffff;
  --text: #1f2937;
  --text-light: #6b7280;
  --border: #e5e7eb;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Inter, sans-serif;
}

body {
  background: var(--background);
  padding: 30px;
}

/* HEADER */

.top-bar {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 25px;
}

.top-bar img {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  object-fit: cover;
}

.top-bar h1 {
  font-size: 22px;
}

.actions {
  margin-left: auto;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn {
  background: var(--primary-light);
  color: var(--primary);
  border: 1px solid var(--border);
  padding: 8px 14px;
  border-radius: 20px;
  font-size: 13px;
  cursor: pointer;
  transition: 0.2s ease;
}

.btn:hover {
  background: var(--primary);
  color: white;
}

/* SEARCH */

.search-bar {
  width: 100%;
  padding: 12px;
  border-radius: 25px;
  border: 1px solid var(--border);
  margin-bottom: 25px;
  font-size: 14px;
}

/* GRID */

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 20px;
}

.card {
  background: var(--card);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  transition: 0.2s ease;
  display: flex;
  flex-direction: column;
}

.card:hover {
  transform: translateY(-4px);
}

.card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 12px;
  margin-bottom: 10px;
}

.card h3 {
  font-size: 16px;
  margin-bottom: 6px;
}

.card p {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 6px;
}

.reserve-btn {
  margin-top: auto;
  background: var(--primary);
  color: white;
  border: none;
  padding: 8px;
  border-radius: 12px;
  cursor: pointer;
  transition: 0.2s;
}

.reserve-btn:hover {
  opacity: 0.85;
}

/* Responsive */

@media (max-width: 600px) {
  body {
    padding: 15px;
  }
}
</style>
</head>

<body>

<div class="top-bar">
  <img src="<%= pdp.pdp || '/uploads/default.png' %>">
  <h1>Bonjour, <%= pr %></h1>

  <div class="actions">
    <button class="btn" onclick="window.location.href='/add'">Ajouter</button>
    <button class="btn" onclick="window.location.href='/mes-annonces'">Mes annonces</button>
    <button class="btn" onclick="window.location.href='/conversations'">Conversations</button>
    <button class="btn" onclick="window.location.href='/settings'">Paramètres</button>
    <button class="btn" onclick="window.location.href='/logout'">Déconnexion</button>
  </div>
</div>

<input type="text" id="searchBar" class="search-bar" placeholder="Rechercher une annonce..." onkeyup="filterGrid()">

<div id="objectGrid" class="grid">
  <% posts.forEach(function(obj) { %>
    <div class="card grid-item">
      <img src="<%= obj.image || '/uploads/default.png' %>">

      <h3><%= obj.titre %></h3>
      <p><%= obj.desc %></p>
      <p><strong><%= obj.auteur_prenom %></strong> — Chambre <%= obj.auteur_chambre %></p>

      <% if (obj.auteur != id) { %>
        <form method="GET" action="/book/<%= obj.id %>">
          <button class="reserve-btn" type="submit">Réserver</button>
        </form>
      <% } %>
    </div>
  <% }); %>
</div>

<script>
function filterGrid() {
  var input = document.getElementById('searchBar');
  var filter = input.value.toLowerCase();
  var items = document.getElementsByClassName('grid-item');

  for (var i = 0; i < items.length; i++) {
    var title = items[i].getElementsByTagName('h3')[0].textContent || '';
    var desc = items[i].getElementsByTagName('p')[0].textContent || '';

    if (title.toLowerCase().includes(filter) || desc.toLowerCase().includes(filter)) {
      items[i].style.display = '';
    } else {
      items[i].style.display = 'none';
    }
  }
}
</script>

</body>
</html>
