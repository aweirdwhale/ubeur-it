<!DOCTYPE html>
<head>
    <title>UbeurIT</title>
</head>
<body>
    <h1>Bonjour, <%= pr %></h1>
    <!-- Search Bar -->
    <input type="text" id="searchBar" placeholder="Rechercher..." onkeyup="filterGrid()">

    <button onclick="window.location.href='/add'" style="margin: 16px 0; padding: 8px 16px; font-size: 16px;">Ajouter une annonce</button>
    <button onclick="window.location.href='/logout'" style="margin: 16px 0; padding: 8px 16px; font-size: 16px;">Se déconnecter</button>
    <button onclick="window.location.href='/mes-annonces'" style="margin: 16px 0; padding: 8px 16px; font-size: 16px;">Mes annonces</button>
    <button onclick="window.location.href='/conversations'" style="margin: 16px 0; padding: 8px 16px; font-size: 16px;">Conversations</button>

    <!-- Grid of Objects -->
    <div id="objectGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px;">
      <% posts.forEach(function(obj) { %>
        <div class="grid-item" style="border: 1px solid #ccc; padding: 16px;">
          <h3><%= obj.titre %></h3>
          <p><%= obj.desc %></p>
          <%console.log(obj.auteur_chambre);%>
          <p>Auteur : <%= obj.auteur_prenom %> (Chambre : <%= obj.auteur_chambre %>)</p>

          <% if (obj.auteur != id) { %>
              <form method="POST" action="/book/<%= obj.id %>">
                  <button type="submit">Réserver</button>
              </form>
          <% } %>

        </div>
      <% }); %>
    </div>

    <script>
      function filterGrid() {
        var input = document.getElementById('searchBar');
        var filter = input.value.toLowerCase();
        var grid = document.getElementById('objectGrid');
        var items = grid.getElementsByClassName('grid-item');
        for (var i = 0; i < items.length; i++) {
          var title = items[i].getElementsByTagName('h3')[0].textContent || '';
          var desc = items[i].getElementsByTagName('p')[0].textContent || '';
          if (title.toLowerCase().indexOf(filter) > -1 || desc.toLowerCase().indexOf(filter) > -1) {
            items[i].style.display = '';
          } else {
            items[i].style.display = 'none';
          }
        }
      }
    </script>
</body>
