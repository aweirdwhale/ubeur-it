<!DOCTYPE html>
<html>
<head>
    <title>Ubeur It</title>
</head>
<body>
    <style>
    /* Reset basique */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Body dark theme */
    body {
        background-color: #121212; /* fond sombre */
        color: #e0e0e0; /* texte clair */
        line-height: 1.6;
        padding: 20px;
    }

    /* Titres */
    h1, h2, h3, h4, h5, h6 {
        color: #ffffff;
        margin-bottom: 16px;
    }

    /* Paragraphes */
    p {
        color: #cccccc;
        margin-bottom: 12px;
    }

    /* Boutons */
    button {
        background-color: #1f1f1f;
        color: #e0e0e0;
        border: 1px solid #333;
        padding: 10px 20px;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    button:hover {
        background-color: #333;
        border-color: #555;
    }

    button:active {
        background-color: #555;
    }

    /* Champs de formulaire (input, textarea) */
    input, textarea, select {
        background-color: #1f1f1f;
        color: #e0e0e0;
        border: 1px solid #333;
        padding: 10px;
        border-radius: 6px;
        width: 100%;
        margin-bottom: 16px;
        transition: all 0.2s ease;
    }

    input:focus, textarea:focus, select:focus {
        outline: none;
        border-color: #5a9bf6; /* accent color bleu */
        box-shadow: 0 0 5px rgba(90, 155, 246, 0.5);
    }

    /* Labels */
    label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
    }

    /* Links */
    a {
        color: #5a9bf6;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

    /* Containers / cards */
    .container {
        background-color: #1a1a1a;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 0 10px rgba(0,0,0,0.3);
    }
    </style>
    <%- body %>
</body>
</html>
